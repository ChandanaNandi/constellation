# Database
POSTGRES_USER=constellation
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=constellation
DATABASE_URL=postgresql+asyncpg://constellation:your_secure_password_here@localhost:5432/constellation

# Redis
REDIS_URL=redis://localhost:6379/0

# Application
DEBUG=false
APP_NAME=Constellation
APP_VERSION=0.1.0

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Weights & Biases
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=constellation

# Model paths
MODEL_CHECKPOINT_DIR=./checkpoints
DATA_DIR=./data
